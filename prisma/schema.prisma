generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Availability {
  id        Int      @id @default(autoincrement())
  postId    Int?
  roomId    Int?
  date      DateTime
  status    String   @default("available")
  price     Float?
  createdAt DateTime @default(now())
  room      Room?    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([roomId, date])
  @@index([postId, date])
}

model Booking {
  id                 Int               @id @default(autoincrement())
  bookingId          String            @unique
  userId             Int
  postId             Int
  roomId             Int?
  checkIn            DateTime
  checkOut           DateTime?
  guests             Int               @default(1)
  totalPrice         Float
  currency           String            @default("RUB")
  status             String            @default("pending")
  paymentStatus      String            @default("unpaid")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  adults             Int               @default(1)
  children           Int               @default(0)
  specialRequests    String?
  source             String            @default("direct")
  commission         Float?
  tax                Float?
  discount           Float             @default(0)
  addons             String?
  deposit            Float             @default(0)
  checkInActual      DateTime?
  checkOutActual     DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  guestPhone         String?
  guestEmail         String?
  promoCode          String?
  discountAmount     Float?
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  post               Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  room               Room?             @relation(fields: [roomId], references: [id])
  BookingNote        BookingNote[]
  BookingPayment     BookingPayment[]
  BookingTimeline    BookingTimeline[]
  contract           Contract?

  @@index([status])
  @@index([postId])
  @@index([userId])
  @@index([paymentStatus])
  @@index([checkIn])
  @@index([source])
}

model ChatMessage {
  id            Int      @id @default(autoincrement())
  userId        Int
  isFromUser    Boolean  @default(true)
  isAiGenerated Boolean  @default(false)
  content       String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model Package {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  price        Float
  duration     Int
  postsLimit   Int           @default(0)
  featured     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userPackages UserPackage[]

  @@unique([id, name])
}

model Post {
  id             Int            @id @default(autoincrement())
  title          String
  slug           String
  type           String
  locale         String         @default("ru")
  content        String?
  excerpt        String?
  status         String         @default("publish")
  authorId       Int?
  featuredImage  String?
  gallery        String?
  address        String?
  latitude       Float?
  longitude      Float?
  price          Float          @default(0)
  salePrice      Float?
  currency       String         @default("RUB")
  rating         Float          @default(0)
  reviewCount    Int            @default(0)
  minNights      Int            @default(1)
  maxNights      Int?
  advanceNoticeHours Int        @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  availabilities Availability[]
  addons         Addon[]
  seasonalPrices SeasonalPrice[]
  bookings       Booking[]
  author         User?          @relation(fields: [authorId], references: [id])
  meta           PostMeta[]
  reviews        Review[]
  rooms          Room[]
  wishlistedBy   Wishlist[]

  @@unique([slug, locale])
}

model Addon {
  id          Int       @id @default(autoincrement())
  postId      Int
  title       String
  description String?
  price       Float
  type        String    @default("extra")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PromoCode {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  discountType  String    @default("percent")
  discountValue Float
  minAmount     Float?    @default(0)
  maxUses       Int?      @default(0)
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SeasonalPrice {
  id        Int      @id @default(autoincrement())
  postId    Int
  roomId    Int?
  label     String   @default("Season")
  fromDate  DateTime
  toDate    DateTime
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  room      Room?    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostMeta {
  id        Int      @id @default(autoincrement())
  postId    Int
  key       String
  value     String?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, key])
}

model Review {
  id          Int      @id @default(autoincrement())
  postId      Int
  userId      Int
  rating      Int
  cleanliness Int?
  location    Int?
  staff       Int?
  value       Int?
  facilities  Int?
  title       String?
  content     String?
  status      String   @default("pending")
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
}

model Room {
  id             Int            @id @default(autoincrement())
  postId         Int
  roomTypeId     Int?
  title          String
  description    String?
  price          Float          @default(0)
  salePrice      Float?
  guests         Int            @default(1)
  beds           Int            @default(1)
  bathrooms      Int            @default(1)
  floor          Int?
  gallery        String?
  amenities      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  availabilities Availability[]
  seasonalPrices SeasonalPrice[]
  bookings       Booking[]
  roomType       RoomType?      @relation(fields: [roomTypeId], references: [id])
  post           Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  facilities     Facility[]     @relation("FacilityToRoom")
}

model RoomType {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rooms       Room[]
}

model Facility {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rooms     Room[]   @relation("FacilityToRoom")
}

model SmsCode {
  phone     String   @id
  code      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                Int               @id @default(autoincrement())
  name              String?
  email             String?           @unique
  emailVerified     DateTime?
  phone             String?           @unique
  phoneVerified     Boolean           @default(false)
  image             String?
  password          String?
  role              String            @default("subscriber")
  citizenship       String?
  identityVerified  Boolean           @default(false)
  identityVerifiedAt DateTime?
  identityNotes     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  accounts          Account[]
  bookings          Booking[]
  BookingNote       BookingNote[]
  BookingTimeline   BookingTimeline[]
  chatMessages      ChatMessage[]
  posts             Post[]
  reviews           Review[]
  sessions          Session[]
  userPackages      UserPackage[]
  identityDocuments IdentityDocument[]
  contracts         Contract[]
  reviewedDocs      IdentityDocument[] @relation("reviewer")
  wishlist          Wishlist[]
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model UserPackage {
  id        Int       @id @default(autoincrement())
  userId    Int
  packageId Int
  startDate DateTime  @default(now())
  endDate   DateTime?
  status    String    @default("active")
  createdAt DateTime  @default(now())
  package   Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, packageId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int
  userId    Int?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BookingNote {
  id        Int      @id @default(autoincrement())
  bookingId Int
  userId    Int?
  content   String
  createdAt DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])
  Booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model BookingPayment {
  id            Int      @id @default(autoincrement())
  bookingId     Int
  amount        Float
  method        String   @default("online")
  status        String   @default("completed")
  transactionId String?
  note          String?
  createdAt     DateTime @default(now())
  Booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model IdentityDocument {
  id            Int      @id @default(autoincrement())
  userId        Int
  docType       String
  encryptedData String
  fileUrl       String?
  fileType      String?
  status        String   @default("pending")
  statusNote    String?
  uploadedAt    DateTime @default(now())
  reviewedAt    DateTime?
  reviewedBy    Int?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer      User?    @relation("reviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
}

model Contract {
  id        Int      @id @default(autoincrement())
  bookingId Int      @unique
  userId    Int
  content   String
  signedAt  DateTime @default(now())
  ipAddress String?
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookingId])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model BookingTimeline {
  id         Int      @id @default(autoincrement())
  bookingId  Int
  fromStatus String?
  toStatus   String
  changedBy  Int?
  note       String?
  createdAt  DateTime @default(now())
  User       User?    @relation(fields: [changedBy], references: [id])
  Booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([bookingId])
}
